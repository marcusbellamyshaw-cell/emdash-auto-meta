{
	"name": "emdash-auto-meta",
	"version": "1.3.0",
	"description": "Emdash CMS plugin that enables AI agents to assign taxonomy terms and set SEO metadata via the content:afterSave hook. Includes Vision LLM for hero image alt text and figcaption generation.",
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"test": "node --experimental-strip-types --test src/*.test.ts"
	},
	"keywords": [
		"emdash",
		"emdash-plugin",
		"cms",
		"ai-agents",
		"mcp",
		"claude",
		"taxonomy",
		"seo",
		"cloudflare-workers",
		"vision",
		"accessibility"
	],
	"author": "Marcus Bellamy-Shaw",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/marcusbellamyshaw-cell/emdash-auto-meta.git"
	},
	"bugs": {
		"url": "https://github.com/marcusbellamyshaw-cell/emdash-auto-meta/issues"
	},
	"homepage": "https://github.com/marcusbellamyshaw-cell/emdash-auto-meta#readme",
	"dependencies": {
		"@anthropic-ai/sdk": "^0.97.1"
	},
	"peerDependencies": {
		"emdash": ">=0.12.0"
	},
	"devDependencies": {
		"emdash": "latest"
	}
}